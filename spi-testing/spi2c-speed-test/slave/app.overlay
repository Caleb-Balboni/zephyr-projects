&flexcomm1_lpspi1 {
	//transfer-delay = <100>;
	//sck-pcs-delay = <200>;
	//pcs-sck-delay = <200>;
	slavefrdm: slavefrdm@0 {
		compatible = "vnd,spi-device";
		reg = <0>;
		spi-max-frequency = <20000000>;
		label = "slave_frdm";
	};
};

&flexcomm1 {
	interrupts = <36 0>;
};

/ {
	dcontainer: dcontainer {
		compatible = "data,container";
		status = "okay";
	};

	spi2cdev: spi2cdev {
		compatible = "hn,spi2c";
		custom-devs = <&dcontainer>;
		sirq-gpios = <&arduino_header ARDUINO_HEADER_R3_D7 GPIO_ACTIVE_HIGH>;
		srdy-gpios = <&arduino_header ARDUINO_HEADER_R3_D6 GPIO_ACTIVE_HIGH>;
		spi-dev = <&slavefrdm>;
	};
};
