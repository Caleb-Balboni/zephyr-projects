&flexcomm1_lpspi1 {
	//transfer-delay = <100>;
	//sck-pcs-delay = <200>;
	//pcs-sck-delay = <200>;
	master_frdm: master_frdm@0 {
		compatible = "vnd,spi-device";
		reg = <0>;
		spi-max-frequency = <20000000>;
		label = "master_frdm";
	};
};

/ {
	zephyr,user {
		sirq-gpios = <&arduino_header ARDUINO_HEADER_R3_D7 GPIO_ACTIVE_HIGH>;
		srdy-gpios = <&arduino_header ARDUINO_HEADER_R3_D6 GPIO_ACTIVE_HIGH>;
	};
};
